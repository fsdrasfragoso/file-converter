{
  "name": "fragosoftware/file-converter",
  "description": "Biblioteca PHP para conversão de arquivos (compatível com Laravel 7+).",
  "type": "library",
  "license": "MIT",
  "keywords": ["laravel", "converter", "files", "conversion"],
  "authors": [
    {
      "name": "Esdras Fragoso da Silva Neto",
      "email": "esdrasfragoso@gmail.com",
      "homepage": "https://fragososoftware.com/"
    }
  ],
  "require": {
    "php": "^7.3 || ^8.0",
    "barryvdh/laravel-dompdf": "^0.9.0",
    "bnbwebexpertise/pdf-to-image": "^1.2",
    "dompdf/dompdf": "^1.2",
    "illuminate/support": "^7.0 || ^8.0 || ^9.0 || ^10.0 || ^11.0",
    "league/commonmark": "^2.8",
    "phpoffice/phppresentation": "^1.2",
    "phpoffice/phpspreadsheet": "1.29",
    "phpoffice/phpword": "^1.4",
    "spatie/image": "^1.10",
    "spatie/pdf-to-image": "^2.3",
    "spatie/pdf-to-text": "^1.54",
    "spatie/temporary-directory": "^2.3"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "orchestra/testbench": "^5.20 || ^6.0 || ^7.0 || ^8.0 || ^9.0"
  },
  "autoload": {
    "psr-4": {
      "FragosoSoftware\\FileConverter\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "FragosoSoftware\\FileConverter\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "vendor/bin/phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}